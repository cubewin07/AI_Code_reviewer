# Application Configuration
PORT=8080
SPRING_PROFILES_ACTIVE=dev

# SQLite Database
DATABASE_URL=jdbc:sqlite:data/reviewer.db

# GitHub App Integration
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=

# 9Router LLM Gateway
NINE_ROUTER_BASE_URL=http://localhost:20128
NINE_ROUTER_API_KEY=
NINE_ROUTER_MODEL=meta-llama/llama-3-70b-instruct
NINE_ROUTER_FALLBACK_MODEL=
NINE_ROUTER_MAX_TOKENS=4096
NINE_ROUTER_TIMEOUT_SECONDS=60

# Background Job Worker
WORKER_CONCURRENCY=2
WORKER_MAX_ATTEMPTS=3
